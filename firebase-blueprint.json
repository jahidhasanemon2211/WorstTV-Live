{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "User favorite channel",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["channelId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "User favorite channels"
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
